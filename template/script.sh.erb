#!/usr/bin/env bash
set -e

MDV_SIF="/gpfs3/well/kir/apps/mdv/mdv.sif"
MDV_DATA_DIR="<%= context.mdv_data_dir %>"
MDV_PROJECTS_DIR="<%= context.mdv_projects_dir %>"

# Flask runs on an internal port; the proxy sits on BIND_PORT (what OOD knows about)
FLASK_PORT=$((BIND_PORT + 1))

echo "$(date): Starting MDV"
echo "  OOD proxy port : ${BIND_PORT}"
echo "  Flask port     : ${FLASK_PORT}"
echo "  Projects       : ${MDV_PROJECTS_DIR}"
echo "  Data           : ${MDV_DATA_DIR}"

mkdir -p "${MDV_DATA_DIR}"
mkdir -p "${MDV_PROJECTS_DIR}"

export APPTAINER_BIND="/gpfs3/well,/gpfs3/users"
export MDV_DATA_DIR
export PORT="${FLASK_PORT}"

# Start MDV container in background on internal port
apptainer run \
  --bind "${MDV_DATA_DIR}:${MDV_DATA_DIR}" \
  --bind "${MDV_PROJECTS_DIR}:/app/mdv" \
  "${MDV_SIF}" &
CONTAINER_PID=$!

# Wait for Flask to be ready before starting the proxy
echo "Waiting for MDV to initialise..."
for i in $(seq 1 90); do
    if curl -sf "http://127.0.0.1:${FLASK_PORT}/" > /dev/null 2>&1; then
        echo "$(date): MDV ready on port ${FLASK_PORT}"
        break
    fi
    sleep 2
done

# Start the path-rewriting proxy on BIND_PORT (OOD connects here)
FLASK_PORT=${FLASK_PORT} BIND_PORT=${BIND_PORT} \
    python3 "<%= session.staged_root %>/proxy.py"
