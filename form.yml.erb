---
cluster: slurm
attributes:
  extra_modules_script:
    label: Extra modules script
    help: If you'd like to load additional modules alongside MDV, put the 'module load ...' commands into a text file (one 'module load...' per line) and specify its path here
    widget: text_field
    required: false
  cores:
    label: Number of CPU cores
    help: How many CPU cores to reserve for your session. NB Ensure this is within the maximum allowed by your chosen partition.
    widget: number_field
    min: 1
    max: 12
    step: 1
    value: 1
    cachable: true
  ram:
    widget: number_field
    label: RAM in GB
    help: How much RAM to reserve for your session. NB Ensure this is within the maximum allowed by your chosen partition
    min: 2
    max:  96
    step: 1
    value: 4
    cachable: true
  bc_num_hours:
    widget: number_field
    help: Maximum runtime in hours for your session. NB Ensure this is within the maximum allowed by your chosen partition
    min: 1
    max: 240
    step: 1
    value: 30
    cachable: true
  bc_email_on_started: false
  auto_modules_mdv_module:
    default: false

  mdv_projects_dir:
    widget: text_field
    label: "MDV projects directory"
    cachable: true
    value: ""
    help: >
      Directory where MDV will store and read your projects.
      ( Pleasse do not use home directory.)
     

  mdv_data_dir:
    widget: text_field
    label: "MDV data directory"
    cachable: true
    value: ""
    help: >
      Directory for MDV internal data (PostgreSQL database, logs).
      Keep this consistent between sessions to preserve your project
      database. (Pleasse do not use home directory.)
form:
  - auto_queues
  - extra_modules_script
  - cores
  - ram
  - bc_num_hours
  - bc_email_on_started
  - mdv_projects_dir
  - mdv_data_dir
