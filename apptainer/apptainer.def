Bootstrap: docker
From: nikolaik/python-nodejs:python3.12-nodejs22

%labels
    Maintainer Dini Senanayake
    Application Multi-Dimensional Viewer (MDV)
    Source https://github.com/Taylor-CCB-Group/MDV

%arguments
    GIT_COMMIT_DATE=unknown
    GIT_BRANCH_NAME=unknown
    GIT_COMMIT_HASH=unknown
    GIT_LAST_COMMIT_MESSAGE=unknown
    BUILD_DATE=unknown
    GIT_DIRTY=false

%environment
    # Vite build-time vars (only relevant if rebuilding frontend inside container)
    export VITE_GIT_COMMIT_DATE="{{ GIT_COMMIT_DATE }}"
    export VITE_GIT_BRANCH_NAME="{{ GIT_BRANCH_NAME }}"
    export VITE_GIT_COMMIT_HASH="{{ GIT_COMMIT_HASH }}"
    export VITE_GIT_LAST_COMMIT_MESSAGE="{{ GIT_LAST_COMMIT_MESSAGE }}"
    export VITE_BUILD_DATE="{{ BUILD_DATE }}"
    export VITE_GIT_DIRTY="{{ GIT_DIRTY }}"

    # Python / Poetry
    export PIP_PREFER_BINARY=1
    export POETRY_VIRTUALENVS_IN_PROJECT=true
    export PATH=/app/python/.venv/bin:$PATH
    export PYTHONPATH=/app/python

    # Locale
    export LANG=C
    export LC_ALL=C

%post
    export DEBIAN_FRONTEND=noninteractive
    export PIP_PREFER_BINARY=1
    export POETRY_VIRTUALENVS_IN_PROJECT=true

    # ── System packages ───────────────────────────────────────────────────────
    apt-get update && apt-get install -y \
        libhdf5-dev \
        netcat-openbsd \
        iputils-ping \
        telnet \
        postgresql \
        postgresql-client \
        git \
        curl \
        ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

    # ── Clone MDV source ──────────────────────────────────────────────────────
    git clone --depth 1 https://github.com/Taylor-CCB-Group/MDV.git /app

    # ── Configure Poetry (in-project venv so it lives at /app/python/.venv) ──
    cd /app/python
    poetry config virtualenvs.in-project true
    poetry install --with dev,backend,auth --no-root
    poetry run python -c "import flask; print('Flask OK')"

    # ── npm install + frontend Vite build ─────────────────────────────────────
    cd /app
    npm install --cache /tmp/.npm-cache
    npm run build-flask-dockerjs

    # ── Install MDV Python package (root package, now source exists) ──────────
    cd /app/python
    poetry install --with dev,backend,auth

    # ── Permissions ───────────────────────────────────────────────────────────
    chmod -R a+rX /app/python/.venv
    chmod -R a+rX /app
    mkdir -p /app/mdv
    chmod 777 /app/mdv

    # ── Startup script ────────────────────────────────────────────────────────
    cat > /usr/local/bin/mdv-start.sh << 'EOF'
#!/bin/bash
# MDV startup script for Apptainer / OpenOnDemand
# Environment variables consumed:
#   MDV_DATA_DIR  - writable directory for pgdata, logs, matplotlib cache (default: ~/mdv_data)
#   PORT          - port for Gunicorn to bind on (default: 5055, OOD sets this automatically)
#   DB_USER       - postgres username (default: mdvuser)
#   DB_PASSWORD   - postgres password (default: mdvpass)
#   DB_NAME       - postgres database name (default: mdvdb)
#   FLASK_ENV     - flask environment (default: production)

set -e

# ── Locate PostgreSQL binaries ────────────────────────────────────────────────
# Debian installs postgres to a versioned path that is not on $PATH by default.
# We resolve the version at runtime so the script works across postgres upgrades.
PG_VERSION=$(ls /usr/lib/postgresql/ | sort -V | tail -1)
export PATH="/usr/lib/postgresql/${PG_VERSION}/bin:${PATH}"

# ── Configuration ─────────────────────────────────────────────────────────────
MDV_DATA_DIR="${MDV_DATA_DIR:-${HOME}/mdv_data}"
PORT="${PORT:-5055}"
DB_USER="${DB_USER:-mdvuser}"
DB_PASSWORD="${DB_PASSWORD:-mdvpass}"
DB_NAME="${DB_NAME:-mdvdb}"
PGDATA="${MDV_DATA_DIR}/pgdata"

mkdir -p "${MDV_DATA_DIR}" "${PGDATA}"

# ── Start embedded PostgreSQL if not already running ──────────────────────────
if ! pg_ctl status -D "${PGDATA}" > /dev/null 2>&1; then
    echo "[mdv] Initialising PostgreSQL in ${PGDATA}..."
    if [ ! -f "${PGDATA}/PG_VERSION" ]; then
        initdb -D "${PGDATA}" --auth=trust --username="${DB_USER}" > /dev/null

        # Use TCP on localhost rather than a Unix socket.
        # MDV constructs a standard postgresql://user:pass@HOST/db URI so the
        # host field must be an IP/hostname, not a filesystem path.
        cat >> "${PGDATA}/postgresql.conf" << PGCONF
listen_addresses = '127.0.0.1'
port = 5432
log_destination = 'stderr'
logging_collector = off
PGCONF

        echo "host all all 127.0.0.1/32 trust" >> "${PGDATA}/pg_hba.conf"
    fi

    pg_ctl start -D "${PGDATA}" -l "${MDV_DATA_DIR}/pg.log" -w -t 30
    sleep 1
    createdb -h 127.0.0.1 -p 5432 -U "${DB_USER}" "${DB_NAME}" 2>/dev/null || true
fi

echo "[mdv] PostgreSQL running on 127.0.0.1:5432"

# ── Export DB connection vars for Flask ───────────────────────────────────────
# DB_HOST must be an IP/hostname - MDV embeds it directly in a postgresql:// URI
export DB_HOST=127.0.0.1
export DB_PORT=5432
export DB_USER="${DB_USER}"
export DB_PASSWORD="${DB_PASSWORD}"
export DB_NAME="${DB_NAME}"
export FLASK_ENV="${FLASK_ENV:-production}"
export PYTHONUNBUFFERED=1

# Matplotlib writes a cache dir; redirect to a writable location under MDV_DATA_DIR
export MPLCONFIGDIR="${MDV_DATA_DIR}/matplotlib"
mkdir -p "${MPLCONFIGDIR}"

# ── Start Gunicorn ────────────────────────────────────────────────────────────
echo "[mdv] Starting MDV on port ${PORT}..."
cd /app/python
exec poetry run gunicorn \
    -k gevent \
    -t 0 \
    -w 1 \
    -b "0.0.0.0:${PORT}" \
    --capture-output \
    --log-level info \
    mdvtools.dbutils.safe_mdv_app:app
EOF

    chmod +x /usr/local/bin/mdv-start.sh

%runscript
    exec /usr/local/bin/mdv-start.sh "$@"

%test
    /app/python/.venv/bin/python -c "import mdvtools; print('mdvtools importable')" || \
        echo "WARN: mdvtools import test failed - check build"
